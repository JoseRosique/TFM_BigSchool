# Environment variables template
# Copy this file to .env and fill in the values for your environment

# Node & Environment
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=meetwithfriends

# Authentication & Security
JWT_SECRET=cambiame_en_produccion
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=cambiame_en_produccion
REFRESH_TOKEN_EXPIRATION=7d
SESSION_SECRET=cambiame_en_produccion
SESSION_TIMEOUT_MS=3600000

# CORS & Security
CORS_ORIGIN=http://localhost:4200
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Email (SMTP)
EMAIL_HOST=tu_smtp
EMAIL_PORT=587
EMAIL_USER=tu_login
EMAIL_PASS=tu_clave_aqui
EMAIL_FROM="MeetWithFriends no-reply@tuapp.com"
FRONTEND_URL=http://localhost:4200

# Frontend
VITE_API_URL=http://localhost:3000

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
