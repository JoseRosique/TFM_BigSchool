{
  "name": "meetwithfriends",
  "version": "1.0.0",
  "description": "Calendar management system for friends",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "install-all": "npm install --legacy-peer-deps",
    "build": "npm run build --workspaces",
    "build:backend": "npm run build --workspace=@meetwithfriends/backend",
    "build:frontend": "npm run build --workspace=@meetwithfriends/frontend",
    "build:shared": "npm run build --workspace=@meetwithfriends/shared",
    "dev": "docker-compose up",
    "dev:build": "docker-compose up --build",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.1.2",
    "@angular/animations": "21.1.2",
    "@angular/cli": "21.1.2",
    "@angular/common": "21.1.2",
    "@angular/compiler": "21.1.2",
    "@angular/compiler-cli": "21.1.2",
    "@angular/core": "21.1.2",
    "@angular/forms": "21.1.2",
    "@angular/platform-browser": "21.1.2",
    "@angular/platform-browser-dynamic": "21.1.2",
    "@angular/router": "21.1.2",
    "@nestjs/cli": "^11.0.16",
    "@playwright/test": "^1.58.1",
    "@types/jest": "^30.0.0",
    "playwright": "^1.58.1",
    "prettier": "3.3.3",
    "rxjs": "7.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "5.9.2",
    "webpack": "5.91.0",
    "zone.js": "0.16.0"
  },
  "dependencies": {}
}
