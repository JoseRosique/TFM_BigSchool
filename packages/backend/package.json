{
  "name": "@meetwithfriends/backend",
  "version": "1.0.0",
  "description": "MeetWithFriends Backend - NestJS + Clean Architecture",
  "author": "MeetWithFriends Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:unit": "jest --testPathPattern='.unit.spec.ts$'",
    "test:integration": "jest --testPathPattern='.integration.spec.ts$'",
    "typeorm": "typeorm-ts-node-commonjs",
    "migrate": "DB_HOST=localhost typeorm-ts-node-commonjs migration:run -d data-source.ts",
    "migrate:generate": "DB_HOST=localhost typeorm-ts-node-commonjs migration:generate -d data-source.ts src/infrastructure/migrations/$npm_config_name",
    "migrate:revert": "DB_HOST=localhost typeorm-ts-node-commonjs migration:revert -d data-source.ts",
    "migrate:create": "typeorm-ts-node-commonjs migration:create -d src/infrastructure/migrations",
    "db:migrate:prod": "export NODE_ENV=production && npm run build && npx typeorm-ts-node-commonjs migration:run -d ./data-source.ts"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@meetwithfriends/shared": "file:../shared",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/throttler": "5.1.2",
    "@nestjs/typeorm": "10.0.2",
    "bcryptjs": "2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "glob": "^13.0.5",
    "google-auth-library": "^10.5.0",
    "helmet": "^7.1.0",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "1.0.0",
    "pg": "^8.12.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "serve-static": "^2.2.1",
    "tslib": "2.6.2",
    "typeorm": "^0.3.28",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "10.1.2",
    "@nestjs/testing": "^10.3.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.30",
    "@types/nodemailer": "^7.0.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "1.0.38",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "prettier": "3.3.3",
    "rimraf": "5.0.9",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.2.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.2"
  }
}
