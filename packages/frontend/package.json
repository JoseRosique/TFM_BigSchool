{
  "name": "@meetwithfriends/frontend",
  "version": "1.0.0",
  "description": "MeetWithFriends Frontend - Angular v18+ with Signals",
  "scripts": {
    "ng": "ng",
    "start": "ts-node scripts/set-env.ts && ng serve --open --poll 1000",
    "build": "ts-node scripts/set-env.ts && ng build",
    "watch": "ts-node scripts/set-env.ts && ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "ng test --watch=true",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.1.2",
    "@angular/common": "21.1.2",
    "@angular/compiler": "21.1.2",
    "@angular/core": "21.1.2",
    "@angular/forms": "21.1.2",
    "@angular/platform-browser": "21.1.2",
    "@angular/platform-browser-dynamic": "21.1.2",
    "@angular/router": "21.1.2",
    "@meetwithfriends/shared": "file:../shared",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "rxjs": "7.8.1",
    "tslib": "2.6.2",
    "zone.js": "0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.1.2",
    "@angular/cli": "21.1.2",
    "@angular/compiler-cli": "21.1.2",
    "@types/jasmine": "5.1.4",
    "@types/node": "20.11.30",
    "dotenv": "^16.4.5",
    "jasmine-core": "5.1.2",
    "karma": "6.4.3",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "ts-node": "^10.9.2",
    "typescript": "5.9.2"
  }
}
